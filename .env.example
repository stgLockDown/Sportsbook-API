# ─── Sportsbook Odds API - Environment Variables ───
# Copy this file to .env and adjust values as needed

# Server Configuration
PORT=8000
HOST=0.0.0.0
WEB_CONCURRENCY=1

# Cache Settings (seconds)
CACHE_TTL=300

# Logging
LOG_LEVEL=info

# Railway sets these automatically:
# PORT - The port Railway assigns
# RAILWAY_ENVIRONMENT - "production"
# RAILWAY_PUBLIC_DOMAIN - Your public URL